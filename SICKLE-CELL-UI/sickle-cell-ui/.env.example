# FalconsScan AI Environment Configuration
# This file provides examples of environment variables
# Copy as .env for development use

# Security & Privacy
REACT_APP_ENV=production
REACT_APP_VERSION=1.0.0

# Disable analytics and tracking
REACT_APP_DISABLE_ANALYTICS=true

# Performance
REACT_APP_ENABLE_SERVICE_WORKER=true

# Note: No API keys, credentials, or user data should be stored in environment variables
# All processing happens locally in the browser
